# Copy this file to .env and fill in your credentials
# Never commit .env to version control

REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
# Optional: defaults to python:devpulse:v{version} if not set
REDDIT_USER_AGENT=python:devpulse:v0.2.0 (by /u/your_reddit_username)

# Required for write operations (posting/commenting)
# Obtain via OAuth2 authorization code flow
REDDIT_USER_REFRESH_TOKEN=

# Comma-separated origins for CORS (frontend URL)
CORS_ORIGINS=http://localhost:3000
